rules_version = '2';

// Regras de segurança do Firebase Storage (fotos de produtos).
// Publique com: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    match /{appId}/produtos/{fileName} {
      allow read: if true; // fotos de produtos podem ser públicas (usadas no catálogo)
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
